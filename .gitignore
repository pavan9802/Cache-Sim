# Maven build output
target/

# JMH benchmark results (large JSON files — committed selectively)
results/*.json
results/*/
results/profiles/
results/flamegraphs/

# IDE files
.idea/
*.iml
.vscode/
*.classpath
*.project
.settings/

# OS metadata
.DS_Store
Thumbs.db

# GC logs
*.log
gc-*.log

# JVM profiling
*.jfr
*.hprof

# Claude Code local settings (user-specific permissions — not shared)
.claude/settings.local.json

# Keep the results directory itself
!results/.gitkeep

# jcstress HTML report output (generated when stress tests are run)
jcstress-results/
